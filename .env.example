# ────────────────────────────────────────────────────────────────────────────
#  PodcastAI Transcriber — environment variables example
# ────────────────────────────────────────────────────────────────────────────
#  Copy this file to `.env` (in the project root) and edit as needed.
#  The app loads `.env` automatically via pydantic-settings.
#  On macOS / Linux:  cp .env.example .env
#  On Windows:        copy .env.example .env
# ────────────────────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────────────────────
# APP_NAME=PodcastAI Transcriber
# APP_VERSION=1.5.0
# DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Database ────────────────────────────────────────────────────────────────
# Override only if you want to store the DB somewhere other than data/app.db
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# DATABASE_SYNC_URL=sqlite:///./data/app.db

# ── Storage ─────────────────────────────────────────────────────────────────
# DATA_DIR=./data

# ── Whisper ─────────────────────────────────────────────────────────────────
# Model size. Options: tiny, base, small, medium, large-v3
# (large-v3 is the default — best quality but needs ~3 GB VRAM)
WHISPER_MODEL=large-v3
# Device is auto-detected (cuda on NVIDIA, metal on Apple Silicon, cpu otherwise)
# Set to "cpu" to force CPU mode.
# WHISPER_DEVICE=auto
# WHISPER_COMPUTE_TYPE=auto
WHISPER_BEAM_SIZE=5
# WHISPER_LANGUAGE=es

# ── MLX Whisper (macOS Apple Silicon only) ──────────────────────────────────
# Used when running on M1/M2/M3/M4 Macs. Install with: pip install mlx-whisper
# Options: mlx-community/whisper-large-v3-mlx (best), whisper-large-v3-turbo (faster)
MLX_WHISPER_MODEL=mlx-community/whisper-large-v3-mlx

# ── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:14b

# ── Pexels (for AI b-rolls) ──────────────────────────────────────────────
# Get a free key at https://www.pexels.com/api/
# Leave empty to use the mock b-rolls in the app.
# PEXELS_API_KEY=

# ── Social media OAuth (opcional) ──────────────────────────────────────────
# Sin estas claves la app usa mock-mode (simula publicaciones, ideal para demos).
# Ver docs/SOCIAL_SETUP.md para instrucciones paso a paso.
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=

# ── File upload limits ──────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=2048
